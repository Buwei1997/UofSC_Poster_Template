% Gemini theme
% https://github.com/anishathalye/gemini

% ====================
% Definitions
% ====================

% USC Garnet, sampled from the Arnold School of Public Health logo
\definecolor{uscgarnet}{HTML}{780030}

% Extra colors
\definecolor{colsec}{HTML}{D9C8CE}
\definecolor{coltert}{HTML}{eeeeee}


% ====================
% Theme
% ====================

% Basic colors
\setbeamercolor{palette primary}{fg=black,bg=white}
\setbeamercolor{palette secondary}{fg=black,bg=white}
\setbeamercolor{palette tertiary}{bg=black,fg=white}
\setbeamercolor{palette quaternary}{fg=black,bg=white}
\setbeamercolor{structure}{fg=uscgarnet}

% Headline
\setbeamercolor{headline}{fg=white,bg=uscgarnet}

% Block
\setbeamercolor{block title}{fg=uscgarnet,bg=white}
\setbeamercolor{block separator}{bg=black}
\setbeamercolor{block body}{fg=black,bg=white}

% Alert Block
\setbeamercolor{block alerted title}{fg=uscgarnet,bg=colsec}
\setbeamercolor{block alerted separator}{bg=black}
\setbeamercolor{block alerted body}{fg=black,bg=colsec}

% Example Block
\setbeamercolor{block example title}{fg=uscgarnet,bg=coltert}
\setbeamercolor{block example separator}{bg=black}
\setbeamercolor{block example body}{fg=black,bg=coltert}

% Heading
\setbeamercolor{heading}{fg=black}

% Itemize
\setbeamercolor{item}{fg=uscgarnet}

% Bibliography
\setbeamercolor{bibliography item}{fg=black}
\setbeamercolor{bibliography entry author}{fg=black}
\setbeamercolor{bibliography entry title}{fg=black}
\setbeamercolor{bibliography entry location}{fg=black}
\setbeamercolor{bibliography entry note}{fg=black}
